{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": [
			"ES2022"
		],
		"strict": true,
		"noImplicitOverride": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"rootDir": "./src",
		"types": [
			"node",
			"mocha"
		],
		"skipLibCheck": true
	},
	"include": [
		"src/**/*"
	]
}